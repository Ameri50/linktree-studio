{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "functions": {
      "dist/server/assets/server.js": {
        "runtime": "nodejs20.x"
      }
    },
    "routes": [
      {
        "src": "/(.*)",
        "dest": "dist/server/assets/server.js"
      }
    ],
    "framework": null
  }